            }
          }
        },
        {
          "name": "GET /admin/users",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/users"
          }
        },
        {
          "name": "GET /admin/reviews",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/reviews"
          }
        },
        {
          "name": "POST /admin/uploads/sign",
          "request": {
            "method": "POST",
            "url": "{{base}}/admin/uploads/sign",
            "header": [
              {
                "key": "X-CSRF-Token",
                "value": "{{csrfToken}}"
              }
            ]
          }
        },
        {
          "name": "GET /admin/stats/sales",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/stats/sales?days=30",
            "header": []
          }
        },
        {
          "name": "GET /admin/stats/top",
          "request": {
            "method": "GET",
            "url": "{{base}}/admin/stats/top",
            "header": []
          }
        },
        {
          "name": "PATCH /admin/users/:id",
          "request": {
            "method": "PATCH",
            "url": "{{base}}/admin/users/{{userId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
