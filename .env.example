# ──────────────────────────────────────────────────
# API (apps/api)
# ──────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Allowed CORS origin(s) — comma-separated in production
# prod: https://lumora.vercel.app
CORS_ORIGINS=http://localhost:3000

# MongoDB Atlas M0 connection string
# Atlas: create cluster → DB user → network 0.0.0.0/0 → copy URI
MONGODB_URI=

# Upstash Redis URL (redis:// or rediss://)
# Upstash: create database → copy URL
REDIS_URL=

# JWT secrets — use long random strings (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token TTLs (ms-compatible strings)
ACCESS_TTL=15m
REFRESH_TTL=7d

# Leave blank locally; set to shared apex domain in prod if needed
COOKIE_DOMAIN=

# Groq API key — console.groq.com → API Keys (no card required)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Cloudinary — dashboard → cloud name + key + secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (optional) — password-reset emails
# If blank, reset tokens are logged to the server console
RESEND_API_KEY=

# ──────────────────────────────────────────────────
# WEB (apps/web)
# ──────────────────────────────────────────────────

# prod: https://lumora-api.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# prod: https://lumora-api.onrender.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# prod: https://lumora.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
