    },
    {
      "name": "AI",
      "item": [
        {
          "name": "POST /ai/chat (SSE)",
          "request": {
            "method": "POST",
            "url": "{{base}}/ai/chat",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              },
              {
                "key": "X-CSRF-Token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Best noise-cancelling earbuds?\" }\n  ]\n}"
            }
          }
        }
      ]
    }
  ]
